// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id           String   @id @default(uuid())
  businessName String
  businessType String
  description  String
  services     String // Stored as JSON string
  contactInfo  String // Stored as JSON string { phone, email, address, whatsapp }
  themeId      String
  theme        Theme    @relation(fields: [themeId], references: [id])
  page         Page?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Page {
  id              String    @id @default(uuid())
  projectId       String    @unique
  project         Project   @relation(fields: [projectId], references: [id])
  title           String
  metaDescription String
  sections        Section[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Section {
  id               String     @id @default(uuid())
  pageId           String
  page             Page       @relation(fields: [pageId], references: [id])
  type             String // hero, about, services, testimonials, faq, cta, footer
  order            Int
  content          String // JSON string of type-specific schema
  isCustomized     Boolean    @default(false)
  generationPrompt String? // The prompt used to generate this section
  revisions        Revision[]
}

model Revision {
  id        String   @id @default(uuid())
  sectionId String
  section   Section  @relation(fields: [sectionId], references: [id])
  content   String // JSON string snapshot
  createdAt DateTime @default(now())
}

model Theme {
  id           String    @id @default(uuid())
  name         String
  colors       String // JSON { primary, secondary, accent, background, text }
  fonts        String // JSON { heading, body }
  borderRadius String
  style        String // modern, classic, bold, minimal, warm
  projects     Project[]
}
